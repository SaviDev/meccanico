---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import '../styles/global.css';

// Load car info
import carInfo from '../data/car_info.json';

// Load & sort interventions by date (newest first)
const interventions = (await getCollection('interventions')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Status badge mapping for vehicle global status
function getGlobalStatusBadge(status: string) {
  switch (status) {
    case 'Marciante':
      return { class: 'badge-marciante', label: 'Marciante' };
    case 'In Officina':
      return { class: 'badge-officina', label: 'In Officina' };
    case 'In attesa di ricambi':
      return { class: 'badge-ricambi', label: 'In attesa di ricambi' };
    default:
      return { class: 'badge-marciante', label: status };
  }
}

// Status badge mapping for intervention status
function getInterventionStatusBadge(status: string) {
  switch (status) {
    case 'Fatto':
      return { class: 'badge-fatto', label: 'Fatto' };
    case 'In Corso':
      return { class: 'badge-in-corso', label: 'In Corso' };
    case 'Da Decidere':
      return { class: 'badge-da-decidere', label: 'Da Decidere' };
    case 'In Diagnosi':
      return { class: 'badge-in-diagnosi', label: 'In Diagnosi' };
    default:
      return { class: 'badge-fatto', label: status };
  }
}

// Format date in Italian
function formatDate(date: Date) {
  return date.toLocaleDateString('it-IT', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

// Format currency
function formatCurrency(amount: number) {
  return amount.toLocaleString('it-IT', {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });
}

const globalBadge = getGlobalStatusBadge(carInfo.global_status);
---

<Layout>
  <main class="min-h-screen">
    <!-- ===== HERO SECTION ===== -->
    <header class="relative overflow-hidden">
      <!-- Gradient orb decorations -->
      <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-[var(--color-accent-blue)] opacity-[0.04] blur-3xl"></div>
      <div class="absolute -bottom-24 -left-24 w-72 h-72 rounded-full bg-[var(--color-accent-cyan)] opacity-[0.04] blur-3xl"></div>

      <div class="max-w-3xl mx-auto px-4 pt-12 pb-10 sm:px-6 sm:pt-16 sm:pb-14">
        <!-- Top bar -->
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl overflow-hidden bg-white flex items-center justify-center">
              <img src="/logo.png" alt="Logo Ranzato Motors" class="w-full h-full object-contain" />
            </div>
            <span class="text-sm font-medium text-slate-400 tracking-wide uppercase">Scheda Veicolo</span>
          </div>
          <a
            href="/admin/"
            id="admin-link"
            class="text-xs font-medium text-slate-500 hover:text-[var(--color-accent-blue)] transition-colors duration-200 flex items-center gap-1.5"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Gestisci
          </a>
        </div>

        <!-- License plate -->
        <div class="mb-6">
          <div id="vehicle-plate" class="inline-block px-5 py-2.5 rounded-xl bg-[var(--color-surface-700)] border border-[var(--color-glass-border)]">
            <span class="text-3xl sm:text-4xl font-extrabold tracking-[0.15em] text-white">
              {carInfo.plate}
            </span>
          </div>
        </div>

        <!-- Vehicle details -->
        <div class="flex flex-wrap items-center gap-x-6 gap-y-3 mb-6">
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Modello</p>
            <p id="vehicle-model" class="text-lg font-semibold text-slate-200">{carInfo.model}</p>
          </div>
          <div class="w-px h-10 bg-[var(--color-glass-border)] hidden sm:block"></div>
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Chilometraggio</p>
            <p id="vehicle-mileage" class="text-lg font-semibold text-slate-200">
              {carInfo.mileage.toLocaleString('it-IT')} <span class="text-sm font-normal text-slate-400">km</span>
            </p>
          </div>
          <div class="w-px h-10 bg-[var(--color-glass-border)] hidden sm:block"></div>
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Stato</p>
            <span id="vehicle-status" class={`badge ${globalBadge.class}`}>{globalBadge.label}</span>
          </div>
        </div>

        <!-- Quick stats -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <div class="glass-card px-4 py-3">
            <p class="text-xs text-slate-500 mb-1">Interventi totali</p>
            <p class="text-xl font-bold text-white">{interventions.length}</p>
          </div>
          <div class="glass-card px-4 py-3">
            <p class="text-xs text-slate-500 mb-1">Completati</p>
            <p class="text-xl font-bold text-[var(--color-accent-green)]">
              {interventions.filter((i) => i.data.status === 'Fatto').length}
            </p>
          </div>
          <div class="glass-card px-4 py-3 col-span-2 sm:col-span-1">
            <p class="text-xs text-slate-500 mb-1">Spesa totale</p>
            <p class="text-xl font-bold text-white">
              €{formatCurrency(
                interventions.reduce((sum, i) => {
                  return sum + (i.data.cost_parts || 0) + (i.data.cost_labor || 0);
                }, 0)
              )}
            </p>
          </div>
        </div>
      </div>

      <!-- Divider -->
      <div class="h-px bg-gradient-to-r from-transparent via-[var(--color-glass-border)] to-transparent"></div>
    </header>

    <!-- ===== TIMELINE SECTION ===== -->
    <section class="max-w-3xl mx-auto px-4 py-10 sm:px-6 sm:py-14">
      <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-8 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Storico Interventi
      </h2>

      <div class="timeline">
        {interventions.map(async (entry, index) => {
          const { Content } = await render(entry);
          const badge = getInterventionStatusBadge(entry.data.status);
          const hasCosts = entry.data.cost_parts || entry.data.cost_labor;
          const totalCost = (entry.data.cost_parts || 0) + (entry.data.cost_labor || 0);

          return (
            <article
              class="timeline-item animate-fade-in-up relative mb-8 last:mb-0"
              id={`intervention-${entry.id}`}
            >
              {/* Timeline node */}
              <div class="timeline-node"></div>

              {/* Card */}
              <div class="glass-card p-5 sm:p-6">
                {/* Header */}
                <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
                  <div>
                    <h3 class="text-base sm:text-lg font-bold text-white mb-1">{entry.data.title}</h3>
                    <time class="text-xs text-slate-500" datetime={entry.data.date.toISOString()}>
                      {formatDate(entry.data.date)}
                    </time>
                  </div>
                  <span class={`badge ${badge.class}`}>{badge.label}</span>
                </div>

                {/* Costs */}
                {hasCosts && (
                  <div class="flex flex-wrap gap-4 mb-4 p-3 rounded-lg bg-[var(--color-surface-800)] border border-[var(--color-glass-border)]">
                    {entry.data.cost_parts != null && entry.data.cost_parts > 0 && (
                      <div>
                        <p class="text-[10px] text-slate-500 uppercase tracking-wider">Materiale</p>
                        <p class="text-sm font-semibold text-slate-300">€{formatCurrency(entry.data.cost_parts)}</p>
                      </div>
                    )}
                    {entry.data.cost_labor != null && entry.data.cost_labor > 0 && (
                      <div>
                        <p class="text-[10px] text-slate-500 uppercase tracking-wider">Manodopera</p>
                        <p class="text-sm font-semibold text-slate-300">€{formatCurrency(entry.data.cost_labor)}</p>
                      </div>
                    )}
                    {totalCost > 0 && (
                      <div class="ml-auto">
                        <p class="text-[10px] text-slate-500 uppercase tracking-wider">Totale</p>
                        <p class="text-sm font-bold text-white">€{formatCurrency(totalCost)}</p>
                      </div>
                    )}
                  </div>
                )}

                {/* Body (rendered markdown) */}
                <div class="prose">
                  <Content />
                </div>

                {/* Image */}
                {entry.data.image && (
                  <div class="mt-4">
                    <img
                      src={entry.data.image}
                      alt={`Foto allegata: ${entry.data.title}`}
                      class="rounded-lg w-full max-h-64 object-cover border border-[var(--color-glass-border)]"
                      loading="lazy"
                    />
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>

      {/* Empty state */}
      {interventions.length === 0 && (
        <div class="text-center py-16">
          <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-[var(--color-surface-700)] flex items-center justify-center">
            <svg class="w-8 h-8 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <p class="text-slate-400 font-medium">Nessun intervento registrato</p>
          <p class="text-sm text-slate-500 mt-1">
            Usa il <a href="/admin/" class="text-[var(--color-accent-blue)] hover:underline">pannello amministrazione</a> per aggiungerne uno.
          </p>
        </div>
      )}
    </section>

    <!-- Footer -->
    <footer class="max-w-3xl mx-auto px-4 pb-8 sm:px-6">
      <div class="h-px bg-gradient-to-r from-transparent via-[var(--color-glass-border)] to-transparent mb-6"></div>
      <p class="text-center text-xs text-slate-600">
        Scheda Veicolo · Officina Meccanica · Aggiornato al {new Date().toLocaleDateString('it-IT')}
      </p>
    </footer>
  </main>
</Layout>
